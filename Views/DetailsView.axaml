<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ShowsHub.Views.DetailsView"
             Background="{DynamicResource AppBackground}">
  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0"
            Background="{DynamicResource SidebarBackground}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="0,0,0,1" Padding="24,14">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="← Înapoi" Command="{Binding BackCommand}"
                Classes="ghost" Padding="10,6"/>
        <TextBlock Text="Detalii" FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" Padding="40,28">
      <StackPanel MaxWidth="720" HorizontalAlignment="Left" Spacing="16">

        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="16" Padding="28">
          <Grid ColumnDefinitions="180,*">

            <Border Grid.Column="0" CornerRadius="10" Width="160" Height="240"
                    ClipToBounds="True" VerticalAlignment="Top">
              <Image Source="{Binding Item.Poster}" Stretch="UniformToFill"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="24,0,0,0" Spacing="12">

              <TextBlock Text="{Binding Item.Title}"
                         FontSize="24" FontWeight="Bold"
                         Foreground="{DynamicResource TextBrush}"
                         TextWrapping="Wrap"/>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <Border Background="{DynamicResource AccentDimBrush}"
                        CornerRadius="10" Padding="10,4" BorderThickness="0">
                  <TextBlock Text="{Binding Item.Type}" FontSize="12" FontWeight="Medium"
                             Foreground="{DynamicResource AccentLightBrush}"/>
                </Border>
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <TextBlock Text="★" Foreground="{DynamicResource GoldBrush}" FontSize="16"/>
                  <TextBlock Text="{Binding Item.Rating}" FontSize="16" FontWeight="SemiBold"
                             Foreground="{DynamicResource GoldBrush}"/>
                  <TextBlock Text="/ 10" FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}"
                             VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                </StackPanel>
                <TextBlock Text="{Binding Item.Year}" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <TextBlock Text="{Binding Item.Overview}"
                         FontSize="13" LineHeight="22"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap"/>

              <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="0,4"/>

              <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding ToggleFavoriteCommand}" Padding="18,9">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="♥" FontSize="14"/>
                    <TextBlock FontSize="13">
                      <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}">
                          <Binding Path="FavoriteLabel"/>
                        </MultiBinding>
                      </TextBlock.Text>
                    </TextBlock>
                  </StackPanel>
                </Button>
                <Button Command="{Binding ToggleWatchlistCommand}"
                        Classes="secondary" Padding="18,9">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🕐" FontSize="13"/>
                    <TextBlock Text="{Binding WatchlistLabel}" FontSize="13"/>
                  </StackPanel>
                </Button>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock FontSize="12" Foreground="{DynamicResource AccentLightBrush}"
                           IsVisible="{Binding IsFavorite}"
                           Text="✓ În lista de favorite"/>
                <TextBlock FontSize="12" Foreground="{DynamicResource GoldBrush}"
                           IsVisible="{Binding IsWatchlist}"
                           Text="✓ În watchlist"/>
              </StackPanel>

            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>