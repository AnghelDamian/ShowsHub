<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ShowsHub.Views.SettingsView"
             Background="{DynamicResource AppBackground}">
  <Grid RowDefinitions="Auto,*">

    <Border Grid.Row="0"
            Background="{DynamicResource SidebarBackground}"
            BorderBrush="{DynamicResource DividerBrush}"
            BorderThickness="0,0,0,1" Padding="24,14">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="← Înapoi" Command="{Binding BackCommand}"
                Classes="ghost" Padding="10,6"/>
        <TextBlock Text="Setări" FontSize="15" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" Padding="40,28">
      <StackPanel MaxWidth="560" HorizontalAlignment="Left" Spacing="20">

        <TextBlock Text="Setări aplicație" FontSize="22" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>

        <!-- TEMA -->
        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="24">
          <StackPanel Spacing="16">
            <TextBlock Text="ASPECT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentLightBrush}" LetterSpacing="2"/>
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Spacing="3">
                <TextBlock Text="Temă deschisă" FontSize="14" FontWeight="Medium"
                           Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="Activează modul light" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
              </StackPanel>
              <CheckBox Grid.Column="1" IsChecked="{Binding IsLightTheme}" VerticalAlignment="Center"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- ACCENT PICKER -->
        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="24">
          <StackPanel Spacing="16">
            <TextBlock Text="CULOARE ACCENT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentLightBrush}" LetterSpacing="2"/>
            <TextBlock Text="Alege culoarea principală a interfeței"
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>

            <ListBox ItemsSource="{Binding AccentOptions}"
                     SelectedItem="{Binding SelectedAccent}"
                     Background="Transparent"
                     BorderThickness="0">
              <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                  <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ListBox.ItemsPanel>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Border CornerRadius="10" Margin="4" Padding="12,8"
                          BorderThickness="0"
                          Width="110">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border Width="18" Height="18" CornerRadius="9"
                              Background="{Binding Preview}"
                              BorderThickness="0"/>
                      <TextBlock Text="{Binding Name}"
                                 FontSize="13" FontWeight="Medium"
                                 Foreground="{DynamicResource TextBrush}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Spacing="6">
              <TextBlock Text="Sau introdu un cod hex personalizat:"
                         FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
              <TextBox Text="{Binding Accent}" Watermark="#FF7C3AED" MaxWidth="200"
                       HorizontalAlignment="Left"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- SAVE -->
        <StackPanel Spacing="10">
          <Button Content="Salvează setările" Command="{Binding SaveCommand}"
                  Padding="24,10" HorizontalAlignment="Left"/>
          <TextBlock Text="{Binding Message}" FontSize="13"
                     Foreground="{DynamicResource AccentLightBrush}"/>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
