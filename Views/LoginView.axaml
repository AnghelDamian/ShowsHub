<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ShowsHub.Views.LoginView">
  <Border CornerRadius="12" Padding="32" Background="{DynamicResource CardBackground}"
          Width="420" HorizontalAlignment="Center" VerticalAlignment="Center"
          BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
    <StackPanel>
      <TextBlock Text="Login" FontSize="26" FontWeight="SemiBold"
                 HorizontalAlignment="Center" Margin="0,0,0,24"
                 Foreground="{DynamicResource TextBrush}"/>

      <TextBlock Text="Username" FontWeight="SemiBold" Margin="0,0,0,6"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBox Text="{Binding Username}" Margin="0,0,0,16"/>

      <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,6"
                 Foreground="{DynamicResource TextSecondaryBrush}"/>
      <TextBox PasswordChar="●" Text="{Binding Password}" Margin="0,0,0,24"/>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
        <Button Content="Login" Command="{Binding LoginCommand}" IsDefault="True" Width="140"/>
        <Button Content="Register" Command="{Binding GoRegisterCommand}" Width="140" Classes="secondary"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
