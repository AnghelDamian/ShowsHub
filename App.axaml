<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ShowsHub.App">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Button">
      <Setter Property="Background" Value="#7C3AED"/>
      <Setter Property="Foreground" Value="#FFFFFFFF"/>
      <Setter Property="BorderBrush" Value="#9D5CF6"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14,9"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#6D28D9"/>
      <Setter Property="BorderBrush" Value="#A78BFA"/>
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="Background" Value="#5B21B6"/>
    </Style>

    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#1C1A2E"/>
      <Setter Property="BorderBrush" Value="#3D3560"/>
      <Setter Property="Foreground" Value="#A78BFA"/>
    </Style>
    <Style Selector="Button.secondary:pointerover">
      <Setter Property="Background" Value="#251E40"/>
      <Setter Property="BorderBrush" Value="#7C3AED"/>
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="Foreground" Value="#94A3B8"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.ghost:pointerover">
      <Setter Property="Foreground" Value="#A78BFA"/>
      <Setter Property="Background" Value="#1C1A2E"/>
    </Style>

    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#7F1D1D"/>
      <Setter Property="BorderBrush" Value="#991B1B"/>
      <Setter Property="Foreground" Value="#FCA5A5"/>
    </Style>
    <Style Selector="Button.danger:pointerover">
      <Setter Property="Background" Value="#991B1B"/>
    </Style>

    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1C1A2E"/>
      <Setter Property="Foreground" Value="#F1F5F9"/>
      <Setter Property="SelectionBrush" Value="#7C3AED55"/>
      <Setter Property="SelectionForegroundBrush" Value="#FFFFFF"/>
      <Setter Property="BorderBrush" Value="#3D3560"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="CaretBrush" Value="#A78BFA"/>
    </Style>
    <Style Selector="TextBox:pointerover">
      <Setter Property="BorderBrush" Value="#7C3AED"/>
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="#7C3AED"/>
      <Setter Property="Foreground" Value="#F1F5F9"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#22204A"/>
      <Setter Property="BorderBrush" Value="#7C3AED"/>
    </Style>
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#1C1A2E"/>
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#1C1A2E"/>
      <Setter Property="Foreground" Value="#F1F5F9"/>
      <Setter Property="BorderBrush" Value="#3D3560"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,7"/>
    </Style>
    <Style Selector="ComboBox:focus">
      <Setter Property="BorderBrush" Value="#7C3AED"/>
    </Style>

    <Style Selector="ListBoxItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#CBD5E1"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="#2D1B69"/>
      <Setter Property="Foreground" Value="#A78BFA"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="#1C1A2E"/>
    </Style>

    <Style Selector="ScrollBar">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
      <Setter Property="Background" Value="#3D3560"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
      <Setter Property="Background" Value="#7C3AED"/>
    </Style>

    <Style Selector="TabItem">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#64748B"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="16,10"/>
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#A78BFA"/>
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#CBD5E1"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style Selector="Slider">
      <Setter Property="Foreground" Value="#7C3AED"/>
    </Style>
    <Style Selector="Slider /template/ Thumb">
      <Setter Property="Background" Value="#7C3AED"/>
      <Setter Property="BorderBrush" Value="#A78BFA"/>
    </Style>

  </Application.Styles>

  <Application.Resources>
    <SolidColorBrush x:Key="AppBackground"          Color="#0A0A0F"/>
    <SolidColorBrush x:Key="SurfaceBackground"      Color="#0F0E1A"/>
    <SolidColorBrush x:Key="CardBackground"         Color="#12111A"/>
    <SolidColorBrush x:Key="CardHoverBackground"    Color="#18162A"/>
    <SolidColorBrush x:Key="PanelBackground"        Color="#0D0C17"/>
    <SolidColorBrush x:Key="SidebarBackground"      Color="#0D0C17"/>
    <SolidColorBrush x:Key="OverlayBackground"      Color="#1A1830"/>

    <SolidColorBrush x:Key="AccentBrush"            Color="#7C3AED"/>
    <SolidColorBrush x:Key="AccentLightBrush"       Color="#A78BFA"/>
    <SolidColorBrush x:Key="AccentDimBrush"         Color="#2D1B69"/>
    <SolidColorBrush x:Key="AccentGlowBrush"        Color="#9D5CF6"/>

    <SolidColorBrush x:Key="GoldBrush"              Color="#F59E0B"/>
    <SolidColorBrush x:Key="GoldLightBrush"         Color="#FCD34D"/>
    <SolidColorBrush x:Key="GoldDimBrush"           Color="#78350F"/>

    <SolidColorBrush x:Key="SuccessBrush"           Color="#10B981"/>
    <SolidColorBrush x:Key="ErrorBrush"             Color="#EF4444"/>
    <SolidColorBrush x:Key="WarningBrush"           Color="#F59E0B"/>

    <SolidColorBrush x:Key="TextBrush"              Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextMutedBrush"         Color="#475569"/>
    <SolidColorBrush x:Key="TextOnAccentBrush"      Color="#FFFFFF"/>

    <SolidColorBrush x:Key="DividerBrush"           Color="#1E1C30"/>
    <SolidColorBrush x:Key="CardBorderBrush"        Color="#231F3A"/>
    <SolidColorBrush x:Key="CardBorderActiveBrush"  Color="#7C3AED"/>
    <SolidColorBrush x:Key="InputBorderBrush"       Color="#3D3560"/>

    <CornerRadius x:Key="CardRadius">12</CornerRadius>
    <CornerRadius x:Key="ButtonRadius">8</CornerRadius>
    <CornerRadius x:Key="ChipRadius">20</CornerRadius>
  </Application.Resources>
</Application>
